---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = await getCollection('posts');

const pinnedPosts = allPosts
	.filter((p) => p.data.pinned)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const latestPosts = allPosts
	.filter((p) => !p.data.pinned)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 3em 1em 2em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2em;
			}
			.hero h1 {
				font-size: 2.5em;
				margin-bottom: 0.3em;
			}
			.hero p {
				color: rgb(var(--gray));
				font-size: 1.1em;
				margin: 0;
			}
			.section {
				max-width: 720px;
				margin: 0 auto 2.5em;
				padding: 0 1em;
			}
			.section-title {
				font-size: 0.85em;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin: 0 0 0.75em;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-list li {
				border-bottom: 1px solid rgb(var(--gray-light));
				padding: 0.75em 0;
			}
			.post-list li:first-child {
				border-top: 1px solid rgb(var(--gray-light));
			}
			.post-list a {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1em;
				text-decoration: none;
				color: rgb(var(--black));
			}
			.post-list a:hover .post-title {
				color: var(--accent);
			}
			.post-title {
				font-weight: 600;
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.5em;
				flex-shrink: 0;
			}
			.post-date {
				color: rgb(var(--gray));
				font-size: 0.9em;
				white-space: nowrap;
			}
			.post-category {
				font-size: 0.78em;
				padding: 0.1em 0.5em;
				border-radius: 999px;
				border: 1px solid rgb(var(--gray-light));
				color: rgb(var(--gray));
				white-space: nowrap;
			}
			.pin-icon {
				font-size: 0.85em;
				margin-right: 0.3em;
				opacity: 0.5;
			}
			.empty-notice {
				color: rgb(var(--gray));
				font-style: italic;
				font-size: 0.9em;
			}
			@media (max-width: 720px) {
				.hero h1 { font-size: 1.8em; }
				.post-category { display: none; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>逍姚故事館</h1>
				<p>日本生活・開發日記・遊戲・音樂・小說・雜雜的</p>
			</section>

			<div class="section">
				<p class="section-title">📌 精選文章</p>
				{pinnedPosts.length > 0 ? (
					<ul class="post-list">
						{pinnedPosts.map((post) => (
							<li>
								<a href={`/posts/${post.id}/`}>
									<span>
										<span class="pin-icon">📌</span>
										<span class="post-title">{post.data.title}</span>
									</span>
									<span class="post-meta">
										<span class="post-category">
											{CATEGORIES[post.data.category]?.emoji} {CATEGORIES[post.data.category]?.name}
										</span>
										<span class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</span>
									</span>
								</a>
							</li>
						))}
					</ul>
				) : (
					<p class="empty-notice">尚無釘選文章，在文章 frontmatter 加上 <code>pinned: true</code> 即可。</p>
				)}
			</div>

			<div class="section">
				<p class="section-title">🕐 最新文章</p>
				{latestPosts.length > 0 ? (
					<ul class="post-list">
						{latestPosts.map((post) => (
							<li>
								<a href={`/posts/${post.id}/`}>
									<span class="post-title">{post.data.title}</span>
									<span class="post-meta">
										<span class="post-category">
											{CATEGORIES[post.data.category]?.emoji} {CATEGORIES[post.data.category]?.name}
										</span>
										<span class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</span>
									</span>
								</a>
							</li>
						))}
					</ul>
				) : (
					<p class="empty-notice">尚無文章。</p>
				)}
			</div>
		</main>
		<Footer />
	</body>
</html>
