---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = await getCollection('posts');

const latestByCategory = Object.fromEntries(
	Object.keys(CATEGORIES).map((cat) => [
		cat,
		allPosts
			.filter((p) => p.data.category === cat)
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
			.slice(0, 2),
	])
);
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 3em 1em 2em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2em;
			}
			.hero h1 {
				font-size: 2.5em;
				margin-bottom: 0.3em;
			}
			.hero p {
				color: rgb(var(--gray));
				font-size: 1.1em;
				margin: 0;
			}
			.categories-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.5rem;
				max-width: 900px;
				margin: 0 auto 3em;
				padding: 0 1em;
			}
			.category-card {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				padding: 1.25em;
				box-shadow: var(--box-shadow);
				transition: box-shadow 0.2s ease;
			}
			.category-card:hover {
				box-shadow: 0 4px 16px rgba(var(--black), 12%);
			}
			.category-header {
				display: flex;
				align-items: center;
				gap: 0.5em;
				margin-bottom: 0.75em;
			}
			.category-header .emoji {
				font-size: 1.4em;
			}
			.category-header h2 {
				margin: 0;
				font-size: 1.1em;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0 0 0.75em 0;
			}
			.post-list li {
				padding: 0.25em 0;
				border-top: 1px solid rgb(var(--gray-light));
				font-size: 0.9em;
			}
			.post-list li:first-child {
				border-top: none;
			}
			.post-list a {
				display: flex;
				justify-content: space-between;
				gap: 0.5em;
				text-decoration: none;
				color: rgb(var(--black));
			}
			.post-list a:hover {
				color: var(--accent);
			}
			.post-list .post-date {
				color: rgb(var(--gray));
				white-space: nowrap;
				flex-shrink: 0;
			}
			.empty-notice {
				color: rgb(var(--gray));
				font-size: 0.9em;
				font-style: italic;
				margin: 0 0 0.75em;
			}
			.see-all {
				display: block;
				text-align: right;
				font-size: 0.85em;
				color: var(--accent);
				text-decoration: none;
			}
			.see-all:hover {
				text-decoration: underline;
			}
			@media (max-width: 720px) {
				.categories-grid {
					grid-template-columns: 1fr;
				}
				.hero h1 {
					font-size: 1.8em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>逍姚故事館</h1>
				<p>日本生活・開發日記・遊戲・音樂・小說・雜雜的</p>
			</section>

			<div class="categories-grid">
				{
					Object.entries(CATEGORIES).map(([slug, { name, emoji }]) => (
						<div class="category-card">
							<div class="category-header">
								<span class="emoji">{emoji}</span>
								<h2>{name}</h2>
							</div>
							{latestByCategory[slug].length > 0 ? (
								<ul class="post-list">
									{latestByCategory[slug].map((post) => (
										<li>
											<a href={`/posts/${post.id}/`}>
												<span>{post.data.title}</span>
												<span class="post-date">
													<FormattedDate date={post.data.pubDate} />
												</span>
											</a>
										</li>
									))}
								</ul>
							) : (
								<p class="empty-notice">尚無文章</p>
							)}
							<a href={`/${slug}/`} class="see-all">查看全部 →</a>
						</div>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>
